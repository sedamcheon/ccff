{
  "rules": {
    ".read": false,
    ".write": false,
    "cafes": {
      ".read": true,
      ".write": "(auth != null && root.child('admins').child(auth.uid).val() === true) || (!data.exists() && newData.exists())"
    },
    "reports": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$reportId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true || (!data.exists() && newData.exists())",
        ".validate": "!newData.exists() || newData.hasChildren(['cafeName', 'drinkName', 'oldPrice', 'newPrice', 'memo', 'createdAt'])"
      }
    },
    "admins": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "newData.isBoolean()"
      }
    }
  }
}
